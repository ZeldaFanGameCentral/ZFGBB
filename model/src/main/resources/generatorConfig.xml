<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN" "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<generatorConfiguration>

  <context id="zfgc3_context" targetRuntime="MyBatis3">

    <!-- Auto-emits AbstractDbo overrides (getPkId, getCreatedTime, getUpdatedTime) on every DBO. -->
    <plugin type="com.zfgc.zfgbb.mbg.DboOverridesPlugin"/>
    <!-- Emits selectByExampleWithRange(Example) on every mapper. -->
    <plugin type="com.zfgc.zfgbb.mbg.PaginatedSelectPlugin"/>

    <jdbcConnection connectionURL="${SPRING_DATASOURCE_URL}?currentSchema=zfgbb"
                    driverClass="org.postgresql.Driver"
                    password="${SPRING_DATASOURCE_PASSWORD}"
                    userId="${SPRING_DATASOURCE_USERNAME}"/>

    <javaModelGenerator targetPackage="com.zfgc.zfgbb.dbo" targetProject="src/main/java">
      <property name="rootClass" value="com.zfgc.zfgbb.dbo.AbstractDbo"/>
    </javaModelGenerator>
    <sqlMapGenerator targetPackage="com.zfgc.zfgbb.mappers" targetProject="src/main/resources"/>
    <javaClientGenerator targetPackage="com.zfgc.zfgbb.mappers" targetProject="src/main/java" type="XMLMAPPER"/>

    <!--
      Convention: list one <table> block per database table here, all commented out by default.
      To regenerate a table's DBO + Example + mapper:
        1. Uncomment its block
        2. Run `mvn initialize mybatis-generator:generate`
        3. Re-comment the block
      The user_karma_view block below is left active because the DTD requires at least one <table>.
    -->

    <table schema="zfgbb" tableName="user_karma_view" domainObjectName="UserKarmaViewDbo">
      <generatedKey column="karma_id" sqlStatement="JDBC" identity="true"/>
      <columnOverride column="karma_given_ts" jdbcType="TIMESTAMP_WITH_TIMEZONE" javaType="java.time.LocalDateTime" isGeneratedAlways="true"/>
      <columnOverride column="is_positive" jdbcType="BOOLEAN" javaType="java.lang.Boolean"/>
    </table>

