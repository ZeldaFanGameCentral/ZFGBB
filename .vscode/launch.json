{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Debug Backend",
            "request": "launch",
            "mainClass": "com.zfgc.zfgbb.ZfgbbApplication",
            "projectName": "zfgbb",
            "envFile": "${workspaceFolder}/.env.local",
            "env": {
                "ZFGBB_CONTENT_PATH": "${workspaceFolder}/backend-assets",
                "ZFGBB_CONTENT_IMAGES": "${workspaceFolder}/backend-assets"
            }
        },
        {
            "type": "java",
            "name": "Debug Backend (Docker postgres)",
            "request": "launch",
            "mainClass": "com.zfgc.zfgbb.ZfgbbApplication",
            "projectName": "zfgbb",
            "preLaunchTask": "Start Postgres (docker compose)",
            "envFile": "${workspaceFolder}/.env.local",
            "env": {
                "ZFGBB_CONTENT_PATH": "${workspaceFolder}/backend-assets",
                "ZFGBB_CONTENT_IMAGES": "${workspaceFolder}/backend-assets"
            }
        }
    ]
}
