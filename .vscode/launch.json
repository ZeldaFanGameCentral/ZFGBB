{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Debug Backend",
            "request": "launch",
            "mainClass": "com.zfgc.zfgbb.ZfgbbApplication",
            "projectName": "zfgbb-app",
            "preLaunchTask": "Maven: install upstream modules",
            "postDebugTask": "Kill ZFGBB backend",
            "envFile": "${workspaceFolder}/.env.local",
            "env": {
                "ZFGBB_CONTENT_PATH": "${workspaceFolder}/backend-assets",
                "ZFGBB_CONTENT_IMAGES": "${workspaceFolder}/backend-assets"
            },
            "console": "integratedTerminal",
            "shortenCommandLine": "auto"
        },
        {
            "type": "java",
            "name": "Debug Backend (Docker postgres)",
            "request": "launch",
            "mainClass": "com.zfgc.zfgbb.ZfgbbApplication",
            "projectName": "zfgbb-app",
            "preLaunchTask": "Prepare Backend (Docker)",
            "postDebugTask": "Kill ZFGBB backend",
            "envFile": "${workspaceFolder}/.env.local",
            "env": {
                "ZFGBB_CONTENT_PATH": "${workspaceFolder}/backend-assets",
                "ZFGBB_CONTENT_IMAGES": "${workspaceFolder}/backend-assets"
            },
            "console": "integratedTerminal",
            "shortenCommandLine": "auto"
        }
    ]
}
